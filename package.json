{
  "name": "orm-dynamodb",
  "version": "1.2.4",
  "description": "Lightweight TypeScript decorators for modeling DynamoDB items as classes",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "dev": "tsx examples.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "prepack": "npm run build",
    "pack:check": "npm pack --dry-run"
  },
  "keywords": [
    "dynamodb",
    "orm-dynamodb",
    "decorators",
    "orm",
    "typescript"
  ],
  "author": "",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/ssz360/ORM-DynamoDB.git"
  },
  "bugs": {
    "url": "https://github.com/ssz360/ORM-DynamoDB/issues"
  },
  "homepage": "https://github.com/ssz360/ORM-DynamoDB",
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.0.0",
    "@aws-sdk/lib-dynamodb": "^3.0.0",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/ui": "^4.1.4",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.4"
  },
  "packageManager": "pnpm@10.11.0+sha512.6540583f41cc5f628eb3d9773ecee802f4f9ef9923cc45b69890fb47991d4b092964694ec3a4f738a420c918a333062c8b925d312f42e4f0c263eb603551f977"
}
